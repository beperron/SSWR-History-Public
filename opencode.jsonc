{
  "$schema": "https://opencode.ai/config.json",
  // OpenCode configuration for SSWR Conference History Database
  // Uses local Ollama models + SSWR Supabase MCP

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27B",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "gpt-oss:20b": {
          "name": "GPT-OSS 20B",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    }
  },

  "mcp": {
    "sswr-history": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anthropic-ai/mcp-supabase@latest",
        "--supabase-url",
        "https://jomsksqqcpkbuhwytovo.supabase.co",
        "--supabase-key",
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpvbXNrc3FxY3BrYnVod3l0b3ZvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQyMDgwODksImV4cCI6MjA1OTc4NDA4OX0.9Vxp6gB03H0MKxrX1ltSCKCumlT-ba5GszWqAAw1Aqg",
        "--read-only"
      ],
      "enabled": true
    }
  }
}
